arks","Student Nominal Rolls","Transfer Certificate","Student Total Credits","Placement Qualified Student","Conduct/Bonafied Certificate","Regular Examfee Paid List","Invigilation Allotment","Affiliated Result Analysis","Exam Time Table","Student Daily Attendance","Subject Based Absent","Grafting","Branchwise Seating","Diploma Certificate Generation","Seating Blocks","JNTU Audit","Final JNTU Report","Transcript","Student Lessthan 5 SGPA","Date Wise Time Table","Overall Mid Marks","Moderation Marks List","Revaluation Marks Analysis","Subjectwise Failed Students","Student Summary","PC Data Excel","Provisional Certificate Report","CMM Data Excel","Photo Zip File","Faculty Time Table","Absent Malpractice","Detention Report","DigiLocker Excel Data","Student Overall Final Data","External Booklet Marks Template","Condonation Paid List","Challenge Fee Paid List","Condonation Fee Not Paid List","Toppers List","Overall TimeTable","Block Students","Day Wise Statement","Student Details Preview","Fee Notification","Overall Internal Excel","Overall MidMarks Excel","Question Paper Generation","DateWise students Feereport","Barcode Generator","Practical Reports","External Faculty Details Excel","Internal Faculty Details","Consolidated Status","Toppers Data","Final Marks","Drawing Structure","Remuneration Bills Amount-Consolidated","Evaluator Valuation","Evaluator Valuation(Other Colleges)","Scrutiny Valuation","Chief Valuation Analysis","Overall Result Excel","Booklet QuestionWise Marks","Remuneration Bills","Raw Marks Report","Internal/External Result Analysis","Academic Bank Credits Excel","Fee Payment Receipt","Internal Marks Status Excel","Internal Pass Not Fee Paid Students","Missing External Manual Valuation","Student Attendance","Backlog Subjects","SubjectWise Registration Students","Observer Report","ExamResults Summary","Mid Awards List","Revaluation Report","Valuation/Assigned/Count","Internal Failed Report","Subject Allotment","Backup-Audit Report","Question Paper Covers","Valuator Status"];o.forwardRef((function(e,t){return o.createElement(J.default,Lw({direction:"up",ref:t},e))}));var jw=_w("div",{className:"allscreens-main-container"},void 0,_w("div",{className:"allscreens-main-heading-main"},void 0,_w("p",{className:"allscreens-main-heading"},void 0,"Reports")),_w("div",{className:"allscreens-main-reference"},void 0,_w(d.Z,{input1:"1. Attendance: Used to consolidate daily student attendance in class.",input2:"2. Notice Board: Used to display important notices and updates for students.",input3:"3. CMM Certificate Generation: Used to generate Consolidated Marks Memo (CMM) certificates for every student.",input4:"4. Student Pass/Fail Report: A consolidated report indicating whether a student has passed or failed in their subjects.",input5:"5. CMM Credit Sheet: Contains the credit details of students, including earned and registered credits.",input6:"6. Roomwise Seating: Displays seating arrangements for students in exam rooms.",input7:"7. D Forms: Contains attendance records, indicating which students are absent or present.",input8:"8. Supple D Forms: Similar to D Forms but specifically for supplementary exams.",input9:"9. Elective Allotment: Indicates which elective courses have been allotted to students.",input10:"10. Final Result Analysis: Provides a consolidated course percentage for branch-wise and overall performance.",input11:"11. Recounting Revaluation Result Analysis: Displays consolidated course percentages for recounting and revaluation.",input12:"12. Revaluation Paid List: Lists students who have paid for revaluation.",input13:"13. Remuneration Report: Contains details of remuneration for valuation and invigilation.",input14:"14. Grade Sheet Generation: Generates reports on student performance in the semester.",input15:"15. Hall Ticket: A ticket for students to enter the examination hall.",input16:"16. OMR (Optical Mark Recognition): Technology that recognizes marks on specially printed examination papers.",input17:"17. Provisional Certificate: Indicates a candidate's class or academic status.",input18:"18. Receipt Details: Provides payment receipts for student transactions.",input19:"19. Supple Exam Fee Paid List: Lists students who have paid supplementary exam fees.",input20:"20. Supple Fee Paid List Student-Wise: Lists students who have paid supplementary exam fees on a student-by-student basis.",input21:"21. Fail By Marks Report: Contains a list of students who failed based on their marks.",input22:"22. Student Nominal Rolls: Provides student status reports that can be filtered by status.",input23:"23. Transfer Certificate: Indicates that a student has either completed their time on the premises or has been removed from the premises.",input24:"24. Student Total Credits: Displays the total credits achieved by students.",input25:"25. Placement Qualified Student: Students without any backlog or, based on certain conditions, students with backlogs will be considered.",input26:"26. Conduct/Bonafied Certificate: A certificate verifying a student's behavior and conduct during their time at the institution.",input27:"27. Fee: The amount of money required for payment in relation to a exam.",input28:"28. Invigilation Allotment: The process of assigning invigilators to oversee and maintain order during examinations.",input29:"29. Affiliated Result Analysis: Used to display the analysis of affiliated results.",input30:"30. Time Table: Used to view the existing examination timetable.",input31:"31. Subject-Based Absent: Used to display absentees in examinations based on subject.",input32:"32. Student Daily Attendance: Used to view daily attendance of students based on dates.",input33:"33. Grafting: Used to display grafted marks for students.",input34:"34. Branchwise Seating: Used to view seating reports branchwise.",input35:"35. Diploma Certificate Generation: Used to generate diploma certificates.",input36:"36. Seating Blocks : Used to show the seating block names which one is allotted for seating.",input37:"37. JNTU Audit : Used to show JNTU audit report for each student.",input38:"38. Transcript : Used to show duplicate certificates where which student pay fee for transcript",input39:"39. Student Lessthan 5 SGPA : Report for which student having lessthan 5 SGPA for the particular semester.",input40:"40. Date Wise Time Table : Used to show the examination time table date wise.",input41:"41. Final Mid Marks : Report for final mid exam marks for each student subjectwise.",input42:"42. Overall Mid Marks : Report for overall mid marks for each student of all subjects.",input43:"43. Moderation Marks List : Report for moderation marks marking students.",input44:"44. Revaluation Marks Analysis : Report for revaluation marks analysis for revaluation applied students.",input45:"45. Subjectwise Failed Students : Report for subjectwise failed students for every regulation.",input46:"46. Student Summary : Report for student entire academic performance analysis.",input47:"47. Valuation Status : Report for Valuation comparision of between valuations.",input48:"48. PC Data Excel : Used to provide PC & CMM issued report for each student.",input49:"49. CMM Data Excel : Used to provide entire all semesters performance of each student.",input50:"50. Photo Zip File : Here we can download Zip file of specific batch students.",input51:"51. Faculty Time Table : Here we can download faculty daywise timetable.",input52:"52. Class Time Table : Here we can download student daywise timetable.",input53:"53. Absent Malpractice : Here we can view and download practiced students.",input54:"54. Detention Report : Here we can download detained student report.",input55:"55. DigiLocker Excel Data : Here we download overall student cmm data in excel for DIGI LOCKER purpose",input56:"56. Student Overall Final Data : Here we can download overall student history data..",input57:"57. Valuation Status Excel : Here we can download comparision of multiple valuation data for external..",input58:"58. External Booklet Marks Template : Here we can download external booklet generated nos template for manual marks entry..",input59:"59. Subject Allotment : Here we can download Alloted subjects"}))),Fw=_w(L(),{className:"excemption_head"},void 0,_w(R(),{},void 0,_w(U(),{},void 0,"S.No"),_w(U(),{},void 0,"User"),_w(U(),{},void 0,"Screen"),_w(U(),{},void 0,"Message"),_w(U(),{},void 0,"Date"),_w(U(),{},void 0,"Time"))),Bw=_w("option",{},void 0,"Select"),zw=_w("option",{value:"PAID"},void 0,"PAID"),Ww=_w("option",{value:"UNPAID"},void 0,"UNPAID"),$w=_w("option",{value:"CONSOLIDATED"},void 0,"CONSOLIDATED"),Jw=_w("option",{},void 0,"Select"),Qw=_w("option",{},void 0,"Select"),Vw=_w("option",{},void 0,"Select"),Gw=_w("option",{value:"All Programs"},void 0,"All Programs"),Zw=_w("option",{},void 0,"Select"),Yw=_w("option",{},void 0,"Select"),Hw=_w("option",{},void 0,"Select"),Xw=_w("option",{value:"Morning"},void 0,"Morning"),Kw=_w("option",{value:"Evening"},void 0,"Evening"),qw=_w("option",{value:"Afternoon"},void 0,"Afternoon"),ek=_w("option",{},void 0,"Select"),tk=_w("option",{},void 0,"Select"),ak=_w("option",{},void 0,"Select"),nk=_w(xe.Z,{}),ok=_w("option",{},void 0,"Select"),rk=_w("option",{},void 0,"Select"),lk=_w("option",{},void 0,"Select"),ik=_w("option",{},void 0,"Select"),sk=_w("option",{},void 0,"Select"),dk=_w("thead",{className:"student_promotion_table_heading"},void 0,_w("th",{},void 0,"S.No"),_w("th",{},void 0,"Roll Number"),_w("th",{},void 0,"Subject"),_w("th",{},void 0,"Marks")),ck=_w(Re,{}),pk=_w("label",{className:"reports-alignment"},void 0,"Degree Type"),mk=_w("option",{},void 0,"Select"),uk=_w("option",{value:"Major"},void 0,"Major"),gk=_w("option",{},void 0,"Select"),vk=_w("option",{},void 0,"Select"),hk=_w("option",{},void 0,"Select"),fk=_w("option",{},void 0,"Select"),bk=_w("option",{value:""},void 0,"Select"),xk=_w("option",{value:"All Rollnos"},void 0,"All Rollnos"),yk=_w(xe.Z,{}),Ak=_w("option",{},void 0,"Select"),Nk=_w("option",{},void 