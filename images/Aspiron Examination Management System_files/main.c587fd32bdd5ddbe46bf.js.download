th: auto, imp !important;\r\n} */\r\n.uploadIconBtnStyleCls {\r\n  color: #0077b6 !important;\r\n  background-color: #ffffff !important;\r\n  border: 0.5px solid #0077b6 !important;\r\n  margin-top: 22px !important;\r\n  border-radius: 10px;\r\n  padding: 10px;\r\n}\r\n.uploadIconBtnStyleCls:hover {\r\n  color: #ffffff !important;\r\n  background-color: #0077b6 !important;\r\n  margin-top: 22px !important;\r\n}\r\n#timeTableClsNew {\r\n  border: 0.5px solid #c6dde0 !important;\r\n}\r\n#timeTableClsNew:hover {\r\n  border: 0.5px solid #c6dde0 !important;\r\n  background-color: #d4e2e3 !important;\r\n}\r\n\r\n.Examtool_allinone_table tr {\r\n  background-color: white;\r\n  vertical-align: middle;\r\n}\r\n.Examtool_allinone_table-feee tr {\r\n  background-color: white;\r\n  vertical-align: middle;\r\n}\r\n\r\n.Examtool_allinone_table-feee tr:nth-child(even) {\r\n  color: #000000;\r\n  /* background-color: #f2f2f2; */\r\n}\r\n\r\n.Examtool_allinone_table select {\r\n  max-width: 250px;\r\n  width: 80%;\r\n  border: 1px solid #ccc !important;\r\n  padding: 8px;\r\n  border-radius: 5px;\r\n  /* background-color: whitesmoke; */\r\n  flex-grow: 1;\r\n  outline: none !important;\r\n}\r\n\r\n.Examtool_allinone_table input:not([type="checkbox"]) {\r\n  max-width: 250px;\r\n  width: 80%;\r\n  border: 1px solid #ccc !important;\r\n  padding: 8px;\r\n  border-radius: 5px;\r\n  /* background-color: whitesmoke; */\r\n  flex-grow: 1;\r\n  min-height: 40px;\r\n  text-align: center;\r\n}\r\n\r\n.Examtool_allinone_table input:focus {\r\n  outline: none;\r\n}\r\n\r\n.Examtool_allinone_table3 {\r\n  text-align: center;\r\n  /* box-shadow: 0 4px 8px 0 rgba(0, 0, 0, 0.2), 0 6px 20px 0 rgba(0, 0, 0, 0.19);\r\n  background-color: rgba(255, 255, 255, 0.3); */\r\n  width: 100%;\r\n  overflow: auto;\r\n  transform: translateX(100%);\r\n  opacity: 0;\r\n  animation: slideInFromTop 1s ease-in-out forwards;\r\n  border-collapse: collapse;\r\n}\r\n\r\n@keyframes slideInFromTop {\r\n  0% {\r\n    transform: translateY(-100%);\r\n    opacity: 0;\r\n  }\r\n\r\n  100% {\r\n    transform: translateY(0);\r\n    opacity: 1;\r\n  }\r\n}\r\n\r\n.Examtool_allinone_table3 tr th,\r\n.Examtool_allinone_table3 tr td {\r\n  padding: 0px;\r\n  font-size: 12px;\r\n  border: 0.5px solid rgb(50, 210, 216);\r\n  width: auto;\r\n}\r\n\r\n.Examtool_allinone_table3 tr th {\r\n  /* border: none; */\r\n  padding-left: 0px;\r\n  font-weight: bold;\r\n  font-family: Arial, Helvetica, sans-serif;\r\n}\r\n\r\n.Examtool_allinone_table3 input {\r\n  max-width: 250px;\r\n  /* width: 80%; */\r\n  border: 1px solid green;\r\n  padding: 2px;\r\n  border-radius: 4px;\r\n  /* background-color: whitesmoke; */\r\n  flex-grow: 1;\r\n  text-align: center;\r\n}\r\n\r\n/* .Examtool_allinone_table3 input:focus {\r\n  outline: none;\r\n} */\r\n\r\n.Examtool_allinone_table1 {\r\n  text-align: center;\r\n  /* box-shadow: 0 4px 8px 0 rgba(0, 0, 0, 0.2), 0 6px 20px 0 rgba(0, 0, 0, 0.19); */\r\n  width: 100%;\r\n  transform: translateX(100%);\r\n  opacity: 0;\r\n  animation: slideInFromTop 1s ease-in-out forwards;\r\n}\r\n.Examtool_allinone_table1 table tr:hover {\r\n  background-color: #d4e2e3 !important;\r\n}\r\n\r\n@keyframes slideInFromTop {\r\n  0% {\r\n    transform: translateY(-100%);\r\n    opacity: 0;\r\n  }\r\n\r\n  100% {\r\n    transform: translateY(0);\r\n    opacity: 1;\r\n  }\r\n}\r\n\r\n.Examtool_allinone_table1 tr th {\r\n  background-color: #0077b6;\r\n  border: none;\r\n  white-space: nowrap;\r\n  padding: 10px;\r\n  color: #fff;\r\n  font-family: Arial, Helvetica, sans-serif;\r\n  letter-spacing: 2px;\r\n  font-weight: 400;\r\n}\r\n\r\n.Examtool_allinone_table1 tr td {\r\n  color: #000000;\r\n  background: white !important;\r\n}\r\n\r\n.Examtool_allinone_table1 tr {\r\n  background-color: rgb(165, 168, 170);\r\n}\r\n\r\n.Examtool_allinone_table1 tr:nth-child(even) {\r\n  color: #000000;\r\n  background-color: #f2f2f2;\r\n}\r\n\r\n.Examtool_allinone_table1 select {\r\n  max-width: 250px;\r\n  border: 0.5px solid rgb(198, 229, 246) !important;\r\n  padding: 8px;\r\n  border-radius: 12px;\r\n  /* background-color: whitesmoke; */\r\n  flex-grow: 1;\r\n}\r\n\r\n.Examtool_allinone_table1 textarea {\r\n  max-width: 250px;\r\n  width: 80%;\r\n  border: 0.5px solid rgb(198, 229, 246) !important;\r\n  padding: 8px;\r\n  border-radius: 12px;\r\n  /* background-color: whitesmoke; */\r\n  flex-grow: 1;\r\n}\r\n\r\n.Examtool_allinone_table1 input {\r\n  max-width: 250px;\r\n  width: 80%;\r\n  border: 0.5px solid rgb(198, 229, 246) !important;\r\n  padding: 8px;\r\n  border-radius: 12px;\r\n  /* background-color: whitesmoke; */\r\n  flex-grow: 1;\r\n  min-height: 40px;\r\n}\r\n\r\n.Examtool_allinone_table1 tr th {\r\n  background-color: #0077b6;\r\n  border: none;\r\n  /* white-space: nowrap; */\r\n  padding: 10px;\r\n  color: #fff;\r\n  font-family: Arial, Helvetica, sans-serif;\r\n  letter-spacing: 2px;\r\n  font-weight: 400;\r\n}\r\n\r\n.Examtool_allinone_table1 tr td {\r\n  color: #000000;\r\n  background: white !important;\r\n}\r\n\r\n.Examtool_allinone_table1 tr {\r\n  background-color: rgb(211, 218, 223);\r\n}\r\n\r\n.Examtool_allinone_table tr:nth-child(even) {\r\n  color: #000000;\r\n  /* background-color: #f2f2f2; */\r\n}\r\n\r\n.Examtool_allinone_table1 select {\r\n  max-width: 250px;\r\n  width: 80%;\r\n  border: 0.5px solid rgb(198, 229, 246) !important;\r\n  padding: 8px;\r\n  border-radius: 12px;\r\n  /* background-color: whitesmoke; */\r\n  flex-grow: 1;\r\n}\r\n\r\n.Examtool_allinone_table1 input {\r\n  max-width: 250px;\r\n  width: 80%;\r\n  border: 0.5px solid rgb(198, 229, 246) !important;\r\n  padding: 8px;\r\n  border-radius: 12px;\r\n  /* background-color: whitesmoke; */\r\n  flex-grow: 1;\r\n  min-height: 40px;\r\n}\r\n\r\n/* Dropdown containers (Adjust dropdown width accordingly) */\r\n.Examtool_allinone_dropdown_container1 {\r\n  display: flex;\r\n  flex-direction: row;\r\n  justify-content: space-around;\r\n  align-items: center;\r\n  /* background-image: linear-gradient(to right, #d1d0d0, #bfa7a1); */\r\n  padding-left: 30px;\r\n  padding-right: 30px;\r\n  /* background-color: #d1d0d0; */\r\n  /* box-shadow: 0 4px 8px 0 rgba(0, 0, 0, 0.2), 0 6px 20px 0 rgba(0, 0, 0, 0.19); */\r\n  border-radius: 10px;\r\n  transform: translateX(0%);\r\n  opacity: 1;\r\n  animation: slideInFromLeft 1s ease-in-out forwards;\r\n}\r\n\r\n@keyframes slideInFromLeft {\r\n  0% {\r\n    transform: translateX(-100%);\r\n    opacity: 0;\r\n  }\r\n\r\n  100% {\r\n    transform: translateX(0);\r\n    opacity: 1;\r\n  }\r\n}\r\n\r\n.Examtool_allinone_dropdown_container2 {\r\n  display: flex;\r\n  flex-direction: row;\r\n  justify-content: flex-start;\r\n  align-items: flex-start;\r\n  padding: 15px;\r\n  /* background-color: #bfa7a1; */\r\n  /* box-shadow: 0 4px 8px 0 rgba(0, 0, 0, 0.2), 0 6px 20px 0 rgba(0, 0, 0, 0.19); */\r\n  border-radius: 10px;\r\n  margin-top: 15px;\r\n  transform: translateX(0%);\r\n  opacity: 1;\r\n  animation: slideInFromRight 1s ease-in-out forwards;\r\n  padding-left: 30px;\r\n  padding-right: 30px;\r\n}\r\n\r\n@keyframes slideInFromRight {\r\n  0% {\r\n    transform: translateX(100%);\r\n    opacity: 0;\r\n  }\r\n\r\n  100% {\r\n    transform: translateX(0);\r\n    opacity: 1;\r\n  }\r\n}\r\n\r\n.Examtool_allinone_dropdown_container3 {\r\n  display: flex;\r\n  justify-content: space-around;\r\n  align-items: center;\r\n  padding: 15px;\r\n  /* background-color: #d6d5d1; */\r\n  /* box-shadow: 0 4px 8px 0 rgba(0, 0, 0, 0.2), 0 6px 20px 0 rgba(0, 0, 0, 0.19); */\r\n  border-radius: 10px;\r\n  transform: translateX(-100%);\r\n  opacity: 0;\r\n  animation: slideInFromLeft 1s ease-in-out forwards;\r\n}\r\n\r\n@keyframes slideInFromLeft {\r\n  0% {\r\n    transform: translateX(-100%);\r\n    opacity: 0;\r\n  }\r\n\r\n  100% {\r\n    transform: translateX(0);\r\n    opacity: 1;\r\n  }\r\n}\r\n\r\n.Examtool_allinone_dropdown {\r\n  display: flex;\r\n  flex-direction: column;\r\n  align-items: flex-start; /* align left */\r\n  justify-content: flex-start;\r\n  flex-grow: 1;\r\n  margin-right: 15px;\r\n}\r\n\r\n.Examtool_allinone_dropdown label {\r\n  color: #02334d !important;\r\n  text-align: left !important;\r\n  width: 100%; /* makes label stretch so text-align works */\r\n  margin-bottom: 4px; /* small spacing above select */\r\n}\r\n\r\n.Examtool_allinone_dropdown select {\r\n  max-width: 200px;\r\n  width: 80%;\r\n  /* color:#7e7676; */\r\n  /* border: 1px solid #ccc; */\r\n  padding: 8px;\r\n  border-radius: 10px;\r\n  /* background-color: #f4f7f9; */\r\n  flex-grow: 1;\r\n  height: 35px;\r\n  text-align: left !important;\r\n  width: 100%; /* makes label stretch so text-align works */\r\n  margin-bottom: 4px; /* small spacing above select */\r\n}\r\n\r\n.form_control {\r\n  max-width: 350px;\r\n  width: 80%;\r\n  border: 2px solid #ccc;\r\n  padding: 8px;\r\n  border-radius: 12px;\r\n  background-color: #f4f7f9;\r\n  flex-grow: 1;\r\n  min-height: 40px;\r\n}\r\n\r\n.Examtool_allinone_dropdown input {\r\n  max-width: 250px;\r\n  width: 80%;\r\n  border: 1px solid #ccd1d1;\r\n  padding: 8px;\r\n  border-radius: 10px;\r\n  /* background-color: #f4f7f9; */\r\n  flex-grow: 1;\r\n  min-height: 30px;\r\n}\r\n\r\n.Examtool_allinone_dropdownsearch {\r\n  display: flex;\r\n  justify-content: flex-end;\r\n  align-items: center;\r\n  width: 100%;\r\n  margin-top: 5px;\r\n}\r\n\r\n.Examtool_allinone_dropdownsearch input {\r\n  max-width: 250px;\r\n  width: 80%;\r\n  border: 2px solid #ccc;\r\n  padding: 8px;\r\n  border-radius: 12px;\r\n  /* background-color: #f4f7f9; */\r\n  flex-grow: 1;\r\n  min-height: 35px;\r\n}\r\n\r\n.Examtool_allinone_dropdown:focus {\r\n  outline: none;\r\n}\r\n\r\n.Examtool_allinone_dropdown select:focus {\r\n  outline: none !important;\r\n}\r\n\r\n.Examtool_allinone_dropdown label {\r\n  color: #02334d;\r\n  font-weight: 700;\r\n  font-family: Arial, Helvetica, sans-serif;\r\n\r\n  flex-grow: 1;\r\n  margin-bottom: 8px;\r\n}\r\n\r\n/* Add Save Buttons */\r\n.Examtool_allinone_btn_container {\r\n  width: 100%;\r\n  display: flex;\r\n  justify-content: flex-end;\r\n  align-items: center;\r\n  margin-top: 10px;\r\n}\r\n\r\n.Examtool_allinone_refbtn_container {\r\n  width: 100%;\r\n  display: flex;\r\n  justify-content: flex-end;\r\n  align-items: flex-end;\r\n  margin-top: 2px;\r\n  margin-left: 89% !important;\r\n}\r\n.Examtool_allinone_refbtn_container-registartion{\r\n  width: 100%;\r\n  display: flex;\r\n  justify-content: flex-end;\r\n  align-items: flex-end;\r\n  margin-top: 2px;\r\n  /* margin-left: 0px !important; */\r\n}\r\n.Examtool_allinone_btn {\r\n  background-color: var(--btn_bg);\r\n  width: fit-content;\r\n  min-width: 120px;\r\n  color: #fff;\r\n  padding: 12px;\r\n  border-radius: 5px;\r\n  font-family: Arial, Helvetica, sans-serif;\r\n  letter-spacing: 1px;\r\n}\r\n\r\n.Examtool_allinone_save_button {\r\n  background-color: white;\r\n  border: 1px solid #02334d;\r\n  padding: 7px;\r\n  border-radius: 5px;\r\n  color: #02334d;\r\n  font-weight: 500;\r\n  font-size: 15px;\r\n  margin-top: 25px;\r\n  padding-left: 20px;\r\n  padding-right: 20px;\r\n  height: auto;\r\n  width: fit-content;\r\n}\r\n.Examtool_allinone_save_button:hover {\r\n  background-color: #02334d;\r\n  color: white;\r\n}\r\n.labelContainerCls {\r\n  display: flex;\r\n  flex-direction: row;\r\n}\r\n.Examtool_allinone_delete_button {\r\n  background-color: white;\r\n  width: fit-content;\r\n  /* min-width: 120px; */\r\n  color: #ff0000;\r\n  border: 0.4px solid #ff0000;\r\n  margin-top: 24px;\r\n  font-weight: 500;\r\n  padding: 10px;\r\n  border-radius: var(--btn_radius);\r\n  padding-left: 20px;\r\n  padding-right: 20px;\r\n}\r\n.Examtool_allinone_delete_button:hover {\r\n  background-color: #ff0000;\r\n  width: fit-content;\r\n  /* min-width: 120px; */\r\n  color: #ffffff;\r\n  /* border: 0.4px solid #FF0000; */\r\n  margin-top: 24px;\r\n  font-weight: 500;\r\n  padding: 10px;\r\n  border-radius: var(--btn_radius);\r\n  padding-left: 20px;\r\n  padding-right: 20px;\r\n}\r\n\r\n/* Save and Delete icons */\r\n\r\n.Examtool_save_icon {\r\n  color: green;\r\n  background-color: transparent;\r\n}\r\n.Examtool_preview_icon {\r\n  color: #02334d;\r\n  background-color: transparent;\r\n}\r\n\r\n.Examtool_dlt_icon {\r\n  color: red;\r\n  background-color: transparent;\r\n}\r\n\r\n/* Add this style to your stylesheet */\r\n.Get_Authentication span:hover {\r\n  background-color: orange;\r\n}\r\n\r\n/* Add this style in your CSS file or <style> tag */\r\n.focused-input {\r\n  border: 2px solid red;\r\n  /* Add any other styling you want for the focused input */\r\n}\r\n\r\n.Examtool_search_container {\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: flex-start;\r\n  width: 100%;\r\n}\r\n\r\n.Examtool_search_input {\r\n  max-width: 350px;\r\n  width: 80%;\r\n  border: 1px solid rgb(98, 233, 233);\r\n  padding: 8px;\r\n  border-radius: 12px;\r\n  /* background-color: whitesmoke; */\r\n  flex-grow: 1;\r\n  min-height: 40px;\r\n  margin-bottom: 10px;\r\n}\r\n.downloadClsNew {\r\n  background-color: white !important;\r\n  border: 1px solid #0077b6 !important;\r\n  color: #0077b6 !important;\r\n  border-radius: 10px !important;\r\n}\r\n.downloadClsNew:hover {\r\n  background-color: #0077b6 !important;\r\n  color: #ffffff !important;\r\n}\r\n\r\n.Examtool_search_input:focus {\r\n  outline: none;\r\n}\r\n\r\n.importAndUploadDiv button {\r\n  background-color: #02334d;\r\n  color: white;\r\n  padding: 8px;\r\n  border-radius: 8px;\r\n  min-width: 120px;\r\n  width: 100px;\r\n  margin-left: 10px;\r\n  margin-top: 20px;\r\n}\r\n\r\n.inputFileAndButton {\r\n  background-color: #fff;\r\n  border-radius: 10px;\r\n  padding: 20px;\r\n  width: 30%;\r\n  margin: auto;\r\n  margin-top: 10px;\r\n}\r\n\r\n.resetAndUploadButtonDiv {\r\n  display: flex;\r\n  /* justify-content: space-between; */\r\n  align-items: center;\r\n}\r\n\r\n.resetAndUploadButtonDiv button {\r\n  background-color: #02334d;\r\n  color: #fff;\r\n  padding: 11px;\r\n  border-radius: 8px;\r\n  min-width: 120px;\r\n  width: 100px;\r\n}\r\n\r\n.anchorButton {\r\n  color: #0077b6 !important;\r\n  background-color: #ffffff !important;\r\n  padding: 11px !important;\r\n  width: 100px;\r\n  border-radius: 5px;\r\n  text-decoration: none;\r\n  border: 0.5px solid #0077b6;\r\n  width: fit-content;\r\n  font-weight: 500;\r\n  padding-left: 16px !important;\r\n  padding-right: 16px !important;\r\n}\r\n.anchorButton:hover {\r\n  color: #ffffff !important;\r\n  background-color: #0077b6 !important;\r\n  padding: 11px !important;\r\n  width: 100px;\r\n  border-radius: 5px;\r\n  text-decoration: none;\r\n  width: fit-content;\r\n  font-weight: 500;\r\n  padding-left: 16px !important;\r\n  padding-right: 16px !important;\r\n}\r\n.anchorButton a {\r\n  text-decoration: none;\r\n  /* color: #fff; */\r\n  color: #0077b6;\r\n}\r\n.anchorButton a:hover {\r\n  text-decoration: none;\r\n  /* color: #fff; */\r\n  color: #ffffff;\r\n}\r\n.ancorTag {\r\n  color: #0077b6 !important;\r\n  /* background-color: #02334D; */\r\n  /* padding: 8px; */\r\n  width: 100px;\r\n  border: 0.5px solid #0077b6;\r\n  background-color: #ffffff;\r\n  border-radius: 8px;\r\n}\r\n.ancorTag:hover {\r\n  color: #ffffff !important;\r\n  /* background-color: #02334D; */\r\n  /* padding: 8px; */\r\n  width: 100px;\r\n  /* border: 0.5px solid #0077B6; */\r\n  background-color: #0077b6;\r\n  border-radius: 8px;\r\n}\r\n\r\n.download_page {\r\n  display: flex;\r\n  justify-content: flex-end;\r\n  align-items: center;\r\n  width: 100%;\r\n  margin-top: 15px;\r\n}\r\n\r\n.searchDiv {\r\n  width: 98%;\r\n  display: flex;\r\n  justify-content: flex-end;\r\n  margin: 10px;\r\n}\r\n\r\n.searchDiv input {\r\n  max-width: 250px;\r\n  width: 80%;\r\n  border: 2px solid #ccc;\r\n  padding: 8px;\r\n  border-radius: 12px;\r\n  background-color: #ffffff;\r\n  flex-grow: 1;\r\n  height: 40px;\r\n}\r\n\r\n.downloadButtonAnchorTag {\r\n  background-color: #02334d;\r\n  color: #fff;\r\n  padding: 4px;\r\n  border-radius: 8px;\r\n  min-width: 120px;\r\n  width: 100px;\r\n  text-decoration: none;\r\n  margin-top: 20px;\r\n  margin-right: 10px;\r\n}\r\n\r\n.facultyUploadContainer {\r\n  display: flex;\r\n  flex-direction: row;\r\n  justify-content: space-around;\r\n  align-items: center;\r\n  border-radius: 10px;\r\n  gap: 50px;\r\n}\r\n\r\n.heading_allotment {\r\n  width: fit-content;\r\n  padding: 12px 30px;\r\n  border-radius: 5px;\r\n  /* background: #2c3e50;\r\n  background: -webkit-linear-gradient(to left, #fd746c, #2c3e50);\r\n  background: linear-gradient(to left, #fd746c, #2c3e50); */\r\n  color: #02334d;\r\n  margin: 10px 0px;\r\n  font-weight: 300;\r\n  font-family: Arial, Helvetica, sans-serif;\r\n  font-size: 18px;\r\n  letter-spacing: 2px;\r\n  margin-bottom: 10px;\r\n}\r\n\r\n.count {\r\n  font-size: 25px;\r\n  font-weight: 400;\r\n  font-family: Arial, Helvetica, sans-serif;\r\n  letter-spacing: 2px;\r\n  margin-left: 10px;\r\n  color: #02334d;\r\n  margin-top: 28px;\r\n}\r\n\r\ninput:focus {\r\n  outline: none;\r\n}\r\n\r\n.facultyInputUpload {\r\n  padding-left: 15px;\r\n  border-radius: 10px;\r\n  display: flex;\r\n  flex-direction: row;\r\n  align-items: center;\r\n  justify-content: flex-start;\r\n  width: 100%;\r\n}\r\n\r\n.uploadandRestButtonContainer {\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n  align-items: center;\r\n  width: 100%;\r\n}\r\n\r\n.facultyResetButton {\r\n  background-color: #d90429;\r\n  width: fit-content;\r\n  min-width: 120px;\r\n  color: #fff;\r\n  padding: 8px;\r\n  border-radius: 5px;\r\n}\r\n\r\n.facultyFileUploadBtn {\r\n  background-color: #02334d;\r\n  width: fit-content;\r\n  min-width: 120px;\r\n  color: #fff;\r\n  padding: 8px;\r\n  border-radius: 5px;\r\n}\r\n\r\n.input_file_cnt {\r\n  background-color: #fff;\r\n\r\n  border-radius: 10px;\r\n  /* box-shadow: 0 4px 8px 0 rgba(0, 0, 0, 0.2), 0 6px 20px 0 rgba(0, 0, 0, 0.19); */\r\n  display: flex;\r\n  flex-direction: column;\r\n  align-items: flex-start;\r\n  justify-content: flex-start;\r\n  width: 100%;\r\n  flex-grow: 1;\r\n}\r\n\r\n/* .fixedHeightScroll{\r\n  height: 300px;\r\n  overflow-y: scroll;\r\n} */\r\n.headerSticky th {\r\n  position: sticky;\r\n  top: 0;\r\n  z-index: 1;\r\n}\r\n\r\n.generalButtonInAllScreens {\r\n  background-color: #02334d;\r\n  width: fit-content;\r\n  min-width: 120px;\r\n  color: #fff;\r\n  padding: 8px;\r\n  border-radius: 5px;\r\n  align-items: center;\r\n  margin-right: 10px;\r\n}\r\n\r\n.sendIcon {\r\n  cursor: pointer;\r\n}\r\n\r\n.sendIcon.active {\r\n  color: green;\r\n}\r\n\r\n.checkBox {\r\n  margin-left: 10px;\r\n}\r\n\r\n.objectiveTimeDown {\r\n  font-size: 30px;\r\n  background-color: white;\r\n  border-radius: 50%; /* This makes it circular */\r\n  padding: 10px;\r\n  color: #02334d;\r\n  margin-bottom: 30px;\r\n  right: 5%;\r\n  z-index: 999999;\r\n  border: 2px solid black;\r\n  width: 120px; /* Add fixed width */\r\n  height: 60px; /* Add fixed height (same as width) */\r\n  display: flex; /* For centering content */\r\n  align-items: center; /* Vertically center content */\r\n  justify-content: center; /* Horizontally center content */\r\n}\r\n.form-container {\r\n  display: flex;\r\n  justify-content: space-between;\r\n}\r\n\r\n.form-column {\r\n  flex: 1;\r\n}\r\n\r\n/* Style for the uploaded file link */\r\n.ant-upload-text-icon {\r\n  font-size: 16px;\r\n  color: #1890ff;\r\n  /* Blue color, adjust as needed */\r\n  text-decoration: underline;\r\n  cursor: pointer;\r\n}\r\n\r\n/* Hover effect for the uploaded file link */\r\n.ant-upload-text-icon:hover {\r\n  color: #40a9ff;\r\n  /* Darker blue on hover, adjust as needed */\r\n}\r\n\r\n.tab-buttons-container {\r\n  display: flex;\r\n}\r\n\r\n.tab-button {\r\n  border: none;\r\n  background-color: transparent;\r\n  cursor: pointer;\r\n  padding: 10px 15px;\r\n  margin-right: 10px;\r\n  color: #000;\r\n}\r\n\r\n.tab-button.active {\r\n  background-color: #02334d;\r\n  color: #fff;\r\n}\r\n\r\n.remuneration_bg {\r\n  padding: 0.8em 1.8em;\r\n  /* border: 2px solid #7ae5db; */\r\n  position: relative;\r\n  overflow: hidden;\r\n  background-color: transparent;\r\n  text-align: center;\r\n  text-transform: uppercase;\r\n  font-size: 16px;\r\n  transition: 0.3s;\r\n  z-index: 1;\r\n  font-family: inherit;\r\n  color: #f7b666;\r\n  /* background-color: lightslategray; */\r\n}\r\n\r\n.remuneration_bg::before {\r\n  content: "";\r\n  width: 0;\r\n  height: 300%;\r\n  position: absolute;\r\n  top: 50%;\r\n  left: 50%;\r\n  transform: translate(-50%, -50%) rotate(45deg);\r\n  /* background: #d9e0e0;  */\r\n  /* background: -webkit-linear-gradient(to right, lightgrey, rgb(199, 232, 242));  \r\n  background: linear-gradient(to right, #e1d5bc, #9fe3e3);  */\r\n  transition: 0.5s ease;\r\n  display: block;\r\n  z-index: -1;\r\n  color: #ffffff;\r\n}\r\n\r\n.remuneration_bg:hover::before {\r\n  width: 105%;\r\n}\r\n\r\n.remuneration_bg:hover {\r\n  color: orange;\r\n}\r\n\r\n.custom-form .ant-form-item-label label {\r\n  color: #02334d;\r\n\r\n  font-weight: bolder;\r\n}\r\n\r\n.generalButton {\r\n  padding: 10px;\r\n  border-radius: 10px;\r\n  min-width: 100px;\r\n  width: 120px;\r\n  background-color: #ffffff !important;\r\n  color: #2c3e50 !important;\r\n  border: 0.5px solid #2c3e50 !important;\r\n}\r\n.generalButton:hover {\r\n  padding: 10px !important;\r\n  border-radius: 10px;\r\n  min-width: 100px;\r\n  width: 120px;\r\n  background-color: #2c3e50 !important;\r\n  color: #ffffff !important;\r\n  /* border:0.5px solid #2C3E50 !important; */\r\n}\r\n\r\n.tableDiv {\r\n  width: 98%;\r\n  display: flex;\r\n  margin: auto;\r\n  margin-top: 15px;\r\n  overflow-x: scroll;\r\n}\r\n\r\n/*  table stylings */\r\n.generalTable {\r\n  text-align: center;\r\n  box-shadow: 0 4px 8px 0 rgba(0, 0, 0, 0.2), 0 6px 20px 0 rgba(0, 0, 0, 0.19);\r\n  width: 100%;\r\n  margin-top: 20px;\r\n  overflow: auto;\r\n  transform: translateX(100%);\r\n  opacity: 0;\r\n  animation: slideInFromTop 1s ease-in-out forwards;\r\n}\r\n\r\n.generalTable tr th {\r\n  background-color: #0077b6;\r\n  border: none;\r\n  white-space: nowrap;\r\n  padding: 10px;\r\n  color: #fff;\r\n  font-family: Arial, Helvetica, sans-serif;\r\n  letter-spacing: 2px;\r\n  font-weight: 400;\r\n}\r\n\r\n.generalTable tr td {\r\n  color: #000000;\r\n  vertical-align: middle;\r\n}\r\n\r\n.generalTable tr {\r\n  background-color: white;\r\n  vertical-align: middle;\r\n}\r\n\r\n.generalTable tr:nth-child(even) {\r\n  color: #000000;\r\n  background-color: #ffffff;\r\n}\r\n\r\n.generalTable select {\r\n  width: 150px;\r\n\r\n  border: 1px solid rgb(98, 233, 233);\r\n  padding: 6px;\r\n  border-radius: 12px;\r\n  /* background-color: whitesmoke; */\r\n  flex-grow: 1;\r\n}\r\n\r\n.generalTable input:not([type="checkbox"]) {\r\n  width: 150px;\r\n\r\n  border: 1px solid rgb(98, 233, 233);\r\n  padding: 4px;\r\n  border-radius: 12px;\r\n  /* background-color: whitesmoke; */\r\n  flex-grow: 1;\r\n  min-height: 40px;\r\n  text-align: center;\r\n}\r\n\r\n.active_btn {\r\n  /* background-color: orange; */\r\n  color: #000000;\r\n  border-radius: 10px;\r\n  -webkit-border-radius: 10px;\r\n  -moz-border-radius: 10px;\r\n  -ms-border-radius: 10px;\r\n  -o-border-radius: 10px;\r\n}\r\n\r\n.Examtool_allinone_heading {\r\n  color: orange;\r\n  text-align: center;\r\n  letter-spacing: 2px;\r\n  font-family: Arial, Helvetica, sans-serif;\r\n  font-weight: 500;\r\n  font-size: 20px;\r\n  margin: 10px;\r\n}\r\n\r\n.Examtool_allinone_heading2 {\r\n  color: orange;\r\n  text-align: center;\r\n  letter-spacing: 2px;\r\n  font-family: Arial, Helvetica, sans-serif;\r\n  font-weight: 550;\r\n  font-size: 20px;\r\n  /* background-color: #fff; */\r\n  padding: 10px 0;\r\n  border-radius: 4px;\r\n  /* background: #948e99; */\r\n  /* fallback for old browsers */\r\n  /* background: -webkit-linear-gradient(to right, #2e1437, #948e99); */\r\n  /* Chrome 10-25, Safari 5.1-6 */\r\n  /* background: linear-gradient(to right, #2e1437, #948e99); */\r\n  /* W3C, IE 10+/ Edge, Firefox 16+, Chrome 26+, Opera 12+, Safari 7+ */\r\n}\r\n\r\n/* NEW  */\r\n\r\n.coloured_table {\r\n  width: 100%;\r\n  overflow: auto;\r\n  /* height: 450px; */\r\n  /* background-color: #fff; */\r\n  /* padding:8px; */\r\n  position: relative;\r\n  padding-bottom: 25px;\r\n  padding-top: 10px;\r\n}\r\n.coloured_table table tr:hover {\r\n  background-color: #d4e2e3 !important;\r\n}\r\n\r\n.colorful_header {\r\n  width: auto;\r\n  height: 50px;\r\n  border: none;\r\n  border-radius: 10px;\r\n  /* background: linear-gradient(to right,#77530a,#ffd277,#77530a,#77530a,#ffd277,#77530a); */\r\n  background-size: 250%;\r\n  background-position: left;\r\n  color: #000000;\r\n  position: relative;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  cursor: pointer;\r\n  transition-duration: 1s;\r\n  overflow: hidden;\r\n}\r\n\r\n.colorful_header::before {\r\n  position: absolute;\r\n  color: #ffd277;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  width: 97%;\r\n  height: 90%;\r\n  border-radius: 8px;\r\n  transition-duration: 1s;\r\n  background-color: rgba(0, 0, 0, 0.842);\r\n  background-size: 200%;\r\n}\r\n\r\n.colorful_header:hover {\r\n  /* background-position: right;\r\n  transition-duration: 1s; */\r\n}\r\n\r\n.colorful_header:hover::before {\r\n  /* background-position: right;\r\n  transition-duration: 1s; */\r\n}\r\n\r\n.colorful_header:active {\r\n  transform: scale(0.95);\r\n}\r\n\r\n.coloured_table_head {\r\n  position: sticky;\r\n  top: -11px;\r\n}\r\n\r\n.coloured_table table {\r\n  width: 100%;\r\n  border-collapse: collapse;\r\n  text-align: center !important;\r\n  /* box-shadow: rgba(0, 0, 0, 0.24) 0px 3px 8px; */\r\n}\r\n\r\n.coloured_table table tr th {\r\n  background-color: white !important;\r\n  color: #02334d !important;\r\n  font-family: Arial, Helvetica, sans-serif;\r\n  /* letter-spacing: 2px; */\r\n  font-weight: 400;\r\n  white-space: nowrap;\r\n  padding: 8px !important;\r\n  outline-style: none;\r\n}\r\n\r\n.coloured_table table select {\r\n  max-width: 250px;\r\n  width: 60%;\r\n  border: 2px solid #ccc;\r\n  padding: 4px;\r\n  border-radius: 12px;\r\n  background-color: #f4f7f9;\r\n  flex-grow: 1;\r\n  height: 35px;\r\n  outline-style: none;\r\n}\r\n\r\n.coloured_table table tr {\r\n  /* background: white; */\r\n  /* fallback for old browsers */\r\n  /* background: -webkit-linear-gradient(to right, #d4d3dd, #efefbb); */\r\n  /* Chrome 10-25, Safari 5.1-6 */\r\n  /* background: linear-gradient(to right, #d4d3dd, #efefbb); */\r\n  /* W3C, IE 10+/ Edge, Firefox 16+, Chrome 26+, Opera 12+, Safari 7+ */\r\n}\r\n\r\n.coloured_table table tr td {\r\n  font-family: Arial, Helvetica, sans-serif;\r\n  color: #02334d;\r\n  letter-spacing: 1px;\r\n  font-weight: 500;\r\n  border: 5px solid #fff;\r\n  white-space: nowrap;\r\n  padding: 0px !important;\r\n  padding-left: 15px !important;\r\n  padding-right: 15px !important;\r\n\r\n  border: 0.5px solid #c6dde0 !important;\r\n}\r\n\r\n.coloured_table table tr td input {\r\n  width: 50px !important;\r\n  padding: 6px;\r\n  border-radius: 5px;\r\n  border: 1px solid #ccc;\r\n  outline: none;\r\n  margin: 5px;\r\n}\r\n\r\n.coloured_table table tr td textarea {\r\n  padding: 6px;\r\n  border-radius: 5px;\r\n  border: 1px solid gray !important;\r\n  outline: none;\r\n}\r\n\r\n/* Less Padding Table */\r\n\r\n.less_padding_table {\r\n  width: 100%;\r\n  overflow: auto;\r\n  /* height: 450px; */\r\n  /* background-color: #fff; */\r\n  /* padding:8px; */\r\n  position: relative;\r\n  padding-bottom: 25px;\r\n}\r\n\r\n.less_padding_table_head {\r\n  position: sticky;\r\n  top: 0;\r\n}\r\n\r\n.less_padding_table table {\r\n  width: 100%;\r\n  border-collapse: collapse;\r\n  text-align: center !important;\r\n  box-shadow: rgba(0, 0, 0, 0.24) 0px 3px 8px;\r\n}\r\n\r\n.less_padding_table table tr th {\r\n  background-color: #003324;\r\n  color: #fff;\r\n  font-family: Arial, Helvetica, sans-serif;\r\n  /* letter-spacing: 2px; */\r\n  font-weight: 400;\r\n  white-space: nowrap;\r\n  padding: 10px !important;\r\n}\r\n\r\n.less_padding_table table tr {\r\n  background: #efefbb;\r\n  /* fallback for old browsers */\r\n  background: -webkit-linear-gradient(to right, #d4d3dd, #efefbb);\r\n  /* Chrome 10-25, Safari 5.1-6 */\r\n  background: linear-gradient(to right, #d4d3dd, #efefbb);\r\n}\r\n\r\n.less_padding_table table tr td {\r\n  font-family: Arial, Helvetica, sans-serif;\r\n  color: #02334d;\r\n  letter-spacing: 1px;\r\n  font-weight: 500;\r\n  border: 5px solid #fff;\r\n  white-space: nowrap;\r\n  padding: 0px !important;\r\n}\r\n\r\n.less_padding_table table tr td input {\r\n  width: 70px !important;\r\n  padding: 6px;\r\n  border-radius: 5px;\r\n  border: 1px solid gray;\r\n  outline: none;\r\n}\r\n\r\n.less_padding_table table tr td textarea {\r\n  padding: 6px;\r\n  border-radius: 5px;\r\n  border: 1px solid gray !important;\r\n  outline: none;\r\n}\r\n\r\n/* newcss */\r\n\r\n.downloadExeclContiner {\r\n  border-radius: 10px;\r\n  margin-right: 10px;\r\n  background: none;\r\n}\r\n\r\n.downloadExeclData {\r\n  font-size: 30px;\r\n  color: green;\r\n}\r\n\r\n.Examtool_tabscontainer {\r\n  /* background-image: linear-gradient(\r\n    to right,\r\n    #0b8793,\r\n    #360033,\r\n    #0b8793,\r\n    #360033\r\n  ); */\r\n  width: 100% !important;\r\n  color: #fff;\r\n  display: flex;\r\n  font-size: 15px !important;\r\n  display: flex;\r\n  flex-direction: row;\r\n  align-items: center;\r\n  height: 30px !important;\r\n  justify-content: center;\r\n  margin-top: 20px;\r\n}\r\n\r\n.Examtool_tabsitems {\r\n  font-size: 10px;\r\n  color: black !important;\r\n  text-transform: uppercase;\r\n  font-family: "Lucida Sans", "Lucida Sans Regular", "Lucida Grande",\r\n    "Lucida Sans Unicode", Geneva, Verdana, sans-serif;\r\n  font-weight: bold;\r\n  /* cursor: pointer; */\r\n  padding: 5px;\r\n  /* transition: background-color 0.3s ease, color 0.3s ease, transform 0.3s ease;  */\r\n  border-radius: 10px;\r\n  height: 20px !important;\r\n}\r\n\r\n.examtool_tab_container_orange {\r\n  background-color: white !important;\r\n  border-bottom: 2px solid #02334d !important;\r\n  color: #ff6700 !important;\r\n  height: 30px !important;\r\n  width: 300px !important;\r\n}\r\n.Examtool_tabsitems:hover {\r\n  background-color: linear-gradient(to right, #0b8793, #360033);\r\n  color: #fff;\r\n  /* transform: scale(1.1); */\r\n  height: 40px !important;\r\n}\r\n\r\n.dailytimetable {\r\n  background-color: #fff !important;\r\n  margin-top: 30px;\r\n  border-radius: 20px;\r\n}\r\n\r\n.sem_wise_marks_download_btn {\r\n  background-color: white;\r\n  color: #0077b6;\r\n  border: 0.5px solid #0077b6;\r\n  margin: 0px;\r\n  padding: 0px;\r\n  align-self: flex-end;\r\n  /* text-align: end; */\r\n  /* width: 100%; */\r\n}\r\n.sem_wise_marks_download_btn:hover {\r\n  background-color: #0077b6;\r\n  color: #ffffff;\r\n  /* border: 0.5px solid #0077B6; */\r\n  margin: 0px;\r\n  padding: 10px;\r\n  border-radius: 10px;\r\n  /* align-self: flex-end; */\r\n  /* width: 100%;\r\n*/\r\n}\r\n/* scrool-bar */\r\n\r\n.custom-scrollbar {\r\n  /* Set the height and width for overflow scrolling */\r\n\r\n  overflow-y: auto;\r\n  /* Enable vertical scrollbar */\r\n\r\n  /* Styles for the scrollbar track */\r\n  scrollbar-width: thin;\r\n  /* For Firefox */\r\n  scrollbar-color: rgba(155, 155, 155, 0.5) rgba(255, 255, 255, 0.3);\r\n  /* For Firefox */\r\n}\r\n\r\n/* Styles for WebKit based browsers like Chrome and Safari */\r\n.custom-scrollbar::-webkit-scrollbar {\r\n  width: 10px;\r\n  /* Example scrollbar width */\r\n}\r\n\r\n.custom-scrollbar::-webkit-scrollbar-thumb {\r\n  background-color: rgba(155, 155, 155, 0.5);\r\n  /* Example thumb color */\r\n  border-radius: 5px;\r\n  /* Example thumb border radius */\r\n}\r\n\r\n.custom-scrollbar::-webkit-scrollbar-track {\r\n  background-color: rgba(255, 255, 255, 0.3);\r\n  /* Example track color */\r\n}\r\n\r\n/* css changed */\r\n.freeze_cls {\r\n  margin-top: 1.8rem;\r\n}\r\n\r\n.Examtool_Animation_btn {\r\n  padding: 1.1em 2em;\r\n  background: none;\r\n  border: 2px solid #fff;\r\n  font-size: 15px;\r\n  color: #fff !important;\r\n  cursor: pointer;\r\n  position: relative;\r\n  overflow: hidden;\r\n  transition: all 0.3s;\r\n  border-radius: 12px;\r\n  background-color: #f2f2f2;\r\n  font-weight: bolder;\r\n  box-shadow: 0 2px 0 2px #000;\r\n}\r\n\r\n.Examtool_Animation_btn:before {\r\n  content: "";\r\n  position: absolute;\r\n  width: 100px;\r\n  height: 60%;\r\n  background-color: #ff6700;\r\n  top: 50%;\r\n  transform: skewX(30deg) translate(-150%, -50%);\r\n  transition: all 0.5s;\r\n}\r\n\r\n.Examtool_Animation_btn:hover {\r\n  /* background-color: orange; */\r\n  color: #fff;\r\n  box-shadow: 0 2px 0 2px #0d3b66;\r\n}\r\n\r\n.Examtool_Animation_btn:hover::before {\r\n  transform: skewX(30deg) translate(150%, -50%);\r\n  transition-delay: 0.1s;\r\n}\r\n\r\n.Examtool_Animation_btn:active {\r\n  transform: scale(0.9);\r\n}\r\n\r\n.model_creation_edit_icon {\r\n  color: green;\r\n  padding: 10px;\r\n}\r\n\r\n.model_creation_delete_icon {\r\n  color: red;\r\n  padding: 10px;\r\n}\r\n\r\n.model_creation_save_icon {\r\n  color: #000;\r\n  padding: 10px;\r\n}\r\n\r\n.Model_creation_Model_name {\r\n  border-left: 5px solid orangered;\r\n  border-radius: 50%;\r\n  padding: 5px 8px;\r\n  font-family: Arial, Helvetica, sans-serif;\r\n  font-size: 18px;\r\n}\r\n\r\n.Qp_models_Datalist {\r\n  border: 3px solid orange;\r\n  border-radius: 5px;\r\n  padding: 5px;\r\n  margin-bottom: 15px;\r\n}\r\n\r\n.sticky_headers {\r\n  position: -webkit-sticky;\r\n  position: sticky;\r\n  left: 0;\r\n  /* background: #efefbb;\r\n  background: -webkit-linear-gradient(to right, #d4d3dd, #efefbb);\r\n  background: linear-gradient(to right, #d4d3dd, #efefbb); */\r\n  z-index: 2;\r\n}\r\n\r\n.sticky_headers + .sticky_headers {\r\n  left: 100px;\r\n  z-index: 1;\r\n}\r\n\r\n/* loader css */\r\n\r\n#Examcell_container {\r\n  width: 100px;\r\n  height: 125px;\r\n  margin: auto auto;\r\n  background-color: rgba(83, 85, 136, 0.501);\r\n}\r\n\r\n.Examcell_loading-title {\r\n  display: block;\r\n  text-align: center !important;\r\n  font-size: 20;\r\n  font-family: "Inter", sans-serif;\r\n  font-weight: bold;\r\n  padding-bottom: 15px;\r\n  color: #888;\r\n}\r\n\r\n.Examcell_loading-circle {\r\n  display: block;\r\n  border-left: 5px solid;\r\n  border-top-left-radius: 100%;\r\n  border-top: 5px solid;\r\n  margin: 5px;\r\n  animation-name: Loader_611;\r\n  animation-duration: 1500ms;\r\n  animation-timing-function: linear;\r\n  animation-delay: 0s;\r\n  animation-iteration-count: infinite;\r\n  animation-direction: normal;\r\n  animation-fill-mode: forwards;\r\n}\r\n\r\n.sp1 {\r\n  border-left-color: #f44336;\r\n  border-top-color: #f44336;\r\n  width: 40px;\r\n  height: 40px;\r\n}\r\n\r\n.sp2 {\r\n  border-left-color: #ffc107;\r\n  border-top-color: #ffc107;\r\n  width: 30px;\r\n  height: 30px;\r\n}\r\n\r\n.sp3 {\r\n  width: 20px;\r\n  height: 20px;\r\n  border-left-color: #8bc34a;\r\n  border-top-color: #8bc34a;\r\n}\r\n\r\n@keyframes Loader_611 {\r\n  0% {\r\n    transform: rotate(0deg);\r\n    transform-origin: right bottom;\r\n  }\r\n\r\n  25% {\r\n    transform: rotate(90deg);\r\n    transform-origin: right bottom;\r\n  }\r\n\r\n  50% {\r\n    transform: rotate(180deg);\r\n    transform-origin: right bottom;\r\n  }\r\n\r\n  75% {\r\n    transform: rotate(270deg);\r\n    transform-origin: right bottom;\r\n  }\r\n\r\n  100% {\r\n    transform: rotate(360deg);\r\n    transform-origin: right bottom;\r\n  }\r\n}\r\n\r\n.commutes {\r\n  display: flex;\r\n  flex-direction: column;\r\n  align-items: center;\r\n  padding: 20px;\r\n}\r\n\r\n.commutes-form {\r\n  display: flex;\r\n  flex-direction: column;\r\n  align-items: center;\r\n  margin-bottom: 20px;\r\n}\r\n\r\n.commutes-form input,\r\n.commutes-form select,\r\n.commutes-form button {\r\n  margin: 10px;\r\n  padding: 10px;\r\n  font-size: 16px;\r\n}\r\n\r\n.commutes-map {\r\n  width: 100%;\r\n  height: 1000px;\r\n}\r\n\r\n/* ReactHTMLTableToExcel */\r\n.download-table-xls-button {\r\n  background-color: #4caf50;\r\n  border: none;\r\n  color: white;\r\n  padding: 10px 20px;\r\n  text-align: center !important;\r\n  text-decoration: none;\r\n  display: inline-block;\r\n  font-size: 16px;\r\n  margin: 4px 2px;\r\n  cursor: pointer;\r\n  border-radius: 5px;\r\n  transition: background-color 0.3s;\r\n}\r\n\r\n.download-table-xls-button-new {\r\n  /* background-color: #4CAF50;  */\r\n  border: none;\r\n  color: white;\r\n  padding: 10px 20px;\r\n  text-align: center !important;\r\n  text-decoration: none;\r\n  display: inline-block;\r\n  font-size: 16px;\r\n  margin: 4px 2px;\r\n  cursor: pointer;\r\n  border-radius: 5px;\r\n  position: absolute;\r\n  top: 0px;\r\n  right: 0px;\r\n  transition: background-color 0.3s;\r\n}\r\n\r\n.download-table-xls-button:hover {\r\n  background-color: #45a049;\r\n}\r\n\r\n.allscreens-main-heading {\r\n  font-family: Arial;\r\n  font-weight: 600;\r\n  font-size: 20px;\r\n  padding: 10px;\r\n  color: #1976d2;\r\n  display: none !important;\r\n}\r\n.allscreens-main-container {\r\n  display: flex;\r\n  width: 100%;\r\n  height: 45px;\r\n}\r\n.allscreens-main-heading-main {\r\n  display: flex;\r\n  justify-content: flex-start;\r\n}\r\n.allscreens-main-reference {\r\n  display: flex;\r\n  justify-content: flex-end;\r\n  width: 100%;\r\n}\r\n\r\n/* priya styles */\r\n\r\n.custom-select.ant-select .ant-select-selector {\r\n  /* border: 1px solid #ccc !important; */\r\n  border-radius: 10px !important;\r\n  height: 45px !important;\r\n  box-shadow: none !important;\r\n  border: none;\r\n}\r\n/* Prevent hover and focus styles */\r\n.custom-select.ant-select:hover .ant-select-selector,\r\n.custom-select.ant-select-focused .ant-select-selector {\r\n  /* border: 1px sol