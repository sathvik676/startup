gin-bottom: 10px;\r\n  font-weight: 400;\r\n}\r\n\r\n\r\n.correctionBlock {\r\n  width: 60%;\r\n  margin-left: 1px;\r\n  /* border: 2px solid skyblue; */\r\n  border-radius: 10px;\r\n  overflow: auto;\r\n  background-color:white;\r\n\r\n}\r\n\r\n.correctionBlockDisabled {\r\n  width: 100%;\r\n  margin-left: 1px;\r\n  border: 2px solid gray;\r\n  border-radius: 10px;\r\n  overflow: hidden;\r\n  background-color: #d3d3d3;\r\n  height: 500px; \r\n}\r\n\r\n.exam-report-wrapper {\r\n  margin-top: 1rem;\r\n  overflow-x: auto;\r\n}\r\n\r\n.exam-report-table {\r\n  width: 100%;\r\n  border-collapse: collapse;\r\n  font-size: 0.875rem;\r\n  background-color: white;\r\n}\r\n\r\n.exam-report-table th,\r\n.exam-report-table td {\r\n  padding: 0.6rem;\r\n  border: 1px solid #e5e7eb;\r\n  vertical-align: top;\r\n}\r\n\r\n.exam-report-table th {\r\n  background-color: #f9fafb;\r\n  font-weight: 600;\r\n  color: #374151;\r\n}\r\n\r\n.exam-report-table tbody tr:nth-child(even) {\r\n  background-color: #f3f4f6;\r\n}\r\n\r\n.exam-report-table tbody tr:hover {\r\n  background-color: #e0f2fe;\r\n}\r\n\r\n.wrap-text {\r\n  white-space: pre-wrap;\r\n  word-break: break-word;\r\n}\r\n\r\n.justification-btn {\r\n  background-color: #2563eb;\r\n  color: white;\r\n  border: none;\r\n  padding: 0.3rem 0.6rem;\r\n  border-radius: 4px;\r\n  cursor: pointer;\r\n  font-size: 0.8rem;\r\n}\r\n\r\n.justification-btn:hover {\r\n  background-color: #1d4ed8;\r\n}\r\n\r\n/* Modal styles */\r\n.feedback-modal-overlay {\r\n  position: fixed;\r\n  top: 0;\r\n  left: 0;\r\n  width: 100%;\r\n  height: 100%;\r\n  background-color: rgba(0,0,0,0.5);\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  z-index: 50;\r\n}\r\n\r\n.feedback-modal {\r\n  background-color: white;\r\n  padding: 1rem 1.5rem;\r\n  border-radius: 8px;\r\n  max-width: 500px;\r\n  width: 90%;\r\n  box-shadow: 0 2px 8px rgba(0,0,0,0.2);\r\n}\r\n\r\n.feedback-modal h3 {\r\n  margin-bottom: 0.5rem;\r\n  font-size: 1.1rem;\r\n  color: #111827;\r\n}\r\n\r\n.feedback-modal p {\r\n  white-space: pre-wrap;\r\n  margin-bottom: 1rem;\r\n  color: #374151;\r\n}\r\n\r\n.close-modal-btn {\r\n  background-color: #dc2626;\r\n  color: white;\r\n  border: none;\r\n  padding: 0.4rem 0.8rem;\r\n  border-radius: 4px;\r\n  cursor: pointer;\r\n}\r\n\r\n.close-modal-btn:hover {\r\n  background-color: #b91c1c;\r\n}\r\n',""]),e.exports=n},821824:(e,t,a)=>{var n=a(260352)((function(e){return e[1]}));n.push([e.id,'body {\r\n    font-family: Arial, sans-serif;\r\n    background-color: #f2f2f2;\r\n    display: flex;\r\n    justify-content: center;\r\n    align-items: center;\r\n    height: 100vh;\r\n}\r\n\r\n.stundetFormMainContainer {\r\n    width: 100%;\r\n    padding: 10px;\r\n    /* background-color: rgba(255, 255, 255, 0.3); */\r\n    /* box-shadow: 0 4px 8px 0 rgba(0, 0, 0, 0.2), 0 6px 20px 0 rgba(0, 0, 0, 0.19); */\r\n    height: fit-content;\r\n    border: 2px solid #fff;\r\n    border-radius: 10px;\r\n    width: 100%;\r\n}\r\n\r\n\r\n\r\n.heading {\r\n    font-size: 36px;\r\n    font-weight: bold;\r\n    margin-bottom: 20px;\r\n    text-align: center;\r\n    color: #02334d;\r\n    /* font-family: "Courier New", Courier, monospace; */\r\n}\r\n\r\n.form-group {\r\n    display: flex;\r\n    flex-wrap: wrap;\r\n    justify-content: space-between;\r\n    margin-bottom: 20px;\r\n}\r\n\r\n.form-group label {\r\n    font-size: 18px;\r\n    font-weight: bold;\r\n    margin-bottom: 10px;\r\n}\r\n\r\n.label {\r\n    width: 100%;\r\n    text-align: center;\r\n    font-weight: bold;\r\n}\r\n\r\n.form-group input,\r\n.form-group select,\r\n.form-group textarea {\r\n    width: 100%;\r\n    padding: 7px;\r\n    border: 1px solid black;\r\n    border-radius: 5px;\r\n    margin-bottom: 10px;\r\n    height: 35px;\r\n}\r\n\r\n.form-group input[type="file"] {\r\n    padding: 5px;\r\n    border: none;\r\n    background-color: #f9f9f9;\r\n}\r\n\r\n.identification-group {\r\n    display: flex;\r\n    justify-content: space-between;\r\n}\r\n\r\n.identification-marks-input-container {\r\n    display: flex;\r\n    flex-wrap: wrap;\r\n    justify-content: space-between;\r\n    width: 600px;\r\n}\r\n\r\n.identification-marks-input-container input {\r\n    flex: 1;\r\n    width: 500px;\r\n    margin-top: 5px;\r\n    border-radius: 5px;\r\n}\r\n\r\n.textarea-field {\r\n    width: 100%;\r\n    height: 100px;\r\n    resize: none;\r\n}\r\n\r\n\r\n\r\n.form_button {\r\n    background-color: #02334d;\r\n    color: white;\r\n    border: none;\r\n    border-radius: 5px;\r\n    padding: 10px 20px;\r\n    font-size: 18px;\r\n    cursor: pointer;\r\n    margin-top: 20px;\r\n    text-align: end;\r\n}\r\n\r\n.image-upload-container input {\r\n    padding: 5px;\r\n    border: none;\r\n    margin-right: 10px;\r\n}\r\n\r\n.course-input {\r\n    padding: 5px;\r\n    border: 1px solid black;\r\n    border-radius: 10px;\r\n    margin-left: 10px;\r\n    margin-right: 10px;\r\n    width: 15vw;\r\n}\r\n\r\n.course-select {\r\n    padding: 5px;\r\n    border: 1px solid black;\r\n    border-radius: 10px;\r\n    margin-left: 90px;\r\n}\r\n\r\n/* Container for the form */\r\n.studentAdmissionFormContainer {\r\n    display: flex;\r\n    justify-content: space-between;\r\n    /* Space evenly between left and right containers */\r\n    align-items: flex-start;\r\n    /* Align items at the top */\r\n    margin: 10px;\r\n    /* Add margin for spacing */\r\n}\r\n\r\n/* Style for left container */\r\n.studentLeftContainer {\r\n    flex: 1;\r\n    /* Take up 50% of the available space */\r\n    padding: 20px;\r\n    /* Add padding to create spacing between elements */\r\n    /* background-color: #BFA7A1; */\r\n    /* Background color for the left container */\r\n    /* border: 1px solid #ddd; */\r\n    /* Add border for separation */\r\n    border-radius: 5px;\r\n    margin-right: 10px;\r\n    /* Add margin between left and right containers */\r\n    /* box-sizing: border-box; */\r\n    /* Include padding and border in the width */\r\n    border-radius: 10px;\r\n}\r\n\r\n/* Style for right container */\r\n.studentRightContainer {\r\n    flex: 1;\r\n    /* Take up 50% of the available space */\r\n    padding: 20px;\r\n    /* Add padding to create spacing between elements */\r\n    /* background-color: #BFA7A1; */\r\n    /* Background color for the right container */\r\n    /* border: 1px solid #ddd; */\r\n    /* Add border for separation */\r\n    border-radius: 5px;\r\n    margin-left: 10px;\r\n    /* Add margin between left and right containers */\r\n    /* box-sizing: border-box; */\r\n    /* Include padding and border in the width */\r\n    border-radius: 10px;\r\n}\r\n\r\n.studentRightContainer label {\r\n    /* font-weight: bold; */\r\n}\r\n\r\n.studentLeftContainer label {\r\n    /* font-weight: bold; */\r\n}\r\n\r\n/* Style for input fields within the containers */\r\n.studentInputFiled {\r\n    width: 50%;\r\n    /* Input fields take up 100% width of their container */\r\n    margin-bottom: 10px;\r\n    border-radius: 8px;\r\n    padding: 4px;\r\n    border: 1px solid black;\r\n    /* Add margin to separate input fields */\r\n}\r\n\r\n.stundentselectFiled {\r\n    width: 100%;\r\n    margin-bottom: 10px;\r\n    border-radius: 8px;\r\n    padding: 4px;\r\n    border: 1px solid black;\r\n}\r\n\r\n/* No need for @media query, as the styles above apply to all screen sizes */\r\n\r\n/* 3rd attempt */\r\n\r\n/* .container{\r\n      width: 85%;\r\n      height: 100%;\r\n      background-color: lightcyan;\r\n      border-radius: 10px;\r\n      align-content: center;\r\n      margin: auto;\r\n      padding: 20px;\r\n      border: solid 2px #02334d;\r\n      display: flex;\r\n      flex-direction: column;\r\n      justify-content: center;\r\n      align-items: center;\r\n    }\r\n    .heading{\r\n        font-size: 20px;\r\n        margin: 5px;\r\n    }\r\n    \r\n    .student-form {\r\n      display: flex;\r\n      flex-direction: column;\r\n      width: 100%;\r\n      align-items